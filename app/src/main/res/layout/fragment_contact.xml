<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="?attr/colorPrimary">
    <LinearLayout android:orientation="vertical" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="Contact Us" android:textColor="@android:color/white" android:textSize="24sp" android:textStyle="bold" />
        <EditText android:id="@+id/contactNameEditText" android:hint="Your Name *" />
        <EditText android:id="@+id/contactEmailEditText" android:hint="Email *" android:inputType="textEmailAddress" />
        <EditText android:id="@+id/contactSubjectEditText" android:hint="Subject *" />
        <EditText android:id="@+id/contactMessageEditText" android:hint="Message *" android:minLines="4" android:gravity="top" />
        <Button android:id="@+id/sendContactBtn" android:text="Send Message" android:layout_marginTop="8dp" />
        <TextView android:text="Connect With Us" android:textColor="@android:color/white" android:textStyle="bold" android:layout_marginTop="24dp" />
        <LinearLayout android:orientation="horizontal" android:weightSum="5" android:layout_width="match_parent" android:layout_height="wrap_content">
            <Button android:id="@+id/btnWhatsapp" android:text="WA" android:layout_weight="1" android:backgroundTint="#25D366" />
            <Button android:id="@+id/btnFacebook" android:text="FB" android:layout_weight="1" android:backgroundTint="#1877F2" />
            <Button android:id="@+id/btnTwitter" android:text="TW" android:layout_weight="1" android:backgroundTint="#000000" />
            <Button android:id="@+id/btnInstagram" android:text="IG" android:layout_weight="1" android:backgroundTint="#E4405F" />
            <Button android:id="@+id/btnYoutube" android:text="YT" android:layout_weight="1" android:backgroundTint="#FF0000" />
        </LinearLayout>
        <Button android:id="@+id/btnTelegram" android:text="Telegram" android:layout_marginTop="8dp" android:backgroundTint="#0088CC" />
        <Button android:id="@+id/btnWebsite" android:text="Visit Our Website" android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>
