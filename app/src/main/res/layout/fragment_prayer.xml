<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prayer Requests"
            android:textColor="?attr/colorOnSurface"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText android:id="@+id/nameEditText" android:hint="Your Name *" android:layout_marginTop="16dp"
            android:textColor="?attr/colorOnSurface" />
        <EditText android:id="@+id/emailEditText" android:hint="Email" android:inputType="textEmailAddress"
            android:textColor="?attr/colorOnSurface" />
        <EditText android:id="@+id/phoneEditText" android:hint="Phone" android:inputType="phone"
            android:textColor="?attr/colorOnSurface" />
        <EditText android:id="@+id/requestEditText" android:hint="Your Prayer Request *" android:minLines="4"
            android:gravity="top" android:layout_marginBottom="16dp" android:textColor="?attr/colorOnSurface" />
        <CheckBox android:id="@+id/followupCheckBox" android:text="I would like follow-up contact"
            android:textColor="?attr/colorOnSurface" />
        <Button android:id="@+id/submitPrayerBtn" android:text="Submit Prayer Request"
            android:layout_marginTop="8dp" style="@style/Widget.MaterialComponents.Button"
            android:backgroundTint="?attr/colorPrimary" android:textColor="?attr/colorOnPrimary" />
    </LinearLayout>
</ScrollView>
