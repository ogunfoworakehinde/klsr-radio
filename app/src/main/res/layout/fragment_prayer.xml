<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="?attr/colorPrimary">
    <LinearLayout android:orientation="vertical" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="Prayer Requests" android:textColor="@android:color/white" android:textSize="24sp" android:textStyle="bold" />
        <EditText android:id="@+id/nameEditText" android:hint="Your Name *" android:layout_marginTop="16dp" />
        <EditText android:id="@+id/emailEditText" android:hint="Email" android:inputType="textEmailAddress" />
        <EditText android:id="@+id/phoneEditText" android:hint="Phone" android:inputType="phone" />
        <EditText android:id="@+id/requestEditText" android:hint="Your Prayer Request *" android:minLines="4" android:gravity="top" />
        <CheckBox android:id="@+id/followupCheckBox" android:text="I would like follow-up contact" android:textColor="@android:color/white" />
        <Button android:id="@+id/submitPrayerBtn" android:text="Submit Prayer Request" android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>
