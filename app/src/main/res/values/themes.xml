<resources>
    <!-- Deep Blue (Light) Theme -->
    <style name="Theme.KLSRRadio" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary = Deep blue for buttons, app bar -->
        <item name="colorPrimary">#0a0f2d</item>
        <item name="colorPrimaryDark">#05081a</item>
        <!-- Accent (unused but kept) -->
        <item name="colorAccent">#0a0f2d</item>

        <!-- Surfaces (cards, pages) -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background of the whole app -->
        <item name="android:colorBackground">#f5f7ff</item>

        <!-- Status bar & navigation -->
        <item name="android:statusBarColor">?attr/colorPrimaryDark</item>
        <item name="android:navigationBarColor">?attr/colorPrimaryDark</item>
    </style>

    <style name="Theme.Splash" parent="Theme.KLSRRadio">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
</resources>
